generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Core Models ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   // "student" | "recruiter" | "admin"
  isVerified   Boolean  @default(false)
  isBanned     Boolean  @default(false)
  lastLogin    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile   StudentProfile?
  recruiterProfile RecruiterProfile?
}

model StudentProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  avatar            String   @default("")
  banner            String   @default("")
  bio               String   @default("")
  college           String   @default("")
  branch            String   @default("")
  year              Int      @default(1)
  skills            String[]
  domains           String[]
  github            String   @default("")
  linkedin          String   @default("")
  portfolio         String   @default("")
  resume            String   @default("")
  certificates      String[]
  achievements      String[]
  badges            String[]
  followers         String[]
  following         String[]
  bookmarks         String[]
  profileViews      Int      @default(0)
  isProfileComplete Boolean  @default(false)
  agreeToTerms      Boolean  @default(true)
}

model RecruiterProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  company           String
  logo              String   @default("")
  industry          String   @default("")
  role              String   @default("")
  hiringInterests   String[]
  description       String   @default("")
  website           String   @default("")
  linkedin          String   @default("")
  savedCandidates   String[]
  shortlisted       String[]
  contactedStudents String[]
}

// ── Hackathon Models ────────────────────────────────────────────────────────

model Hackathon {
  id                String   @id @default(uuid())
  name              String
  tagline           String   @default("")
  description       String   @default("")
  banner            String   @default("")
  deadline          DateTime
  status            String   // "draft" | "active" | "judging" | "completed"
  judgeToken        String   @unique
  judgePasswordHash String
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tracks        HackathonTrack[]
  announcements HackathonAnnouncement[]
  teams         HackathonTeam[]
  participants  HackathonParticipant[]
  projects      HackathonProject[]
}

model HackathonTrack {
  id               String    @id @default(uuid())
  hackathonId      String
  hackathon        Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  name             String
  description      String
  problemStatement String
  openInnovation   Boolean   @default(false)
}

model HackathonAnnouncement {
  id          String    @id @default(uuid())
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  text        String
  type        String    // "info" | "warning" | "success" | "urgent"
  timestamp   DateTime  @default(now())
}

model HackathonTeam {
  id            String   @id @default(uuid())
  hackathonId   String
  hackathon     Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  name          String
  passwordHash  String
  plainPassword String
  leaderId      String
  memberIds     String[] // Store IDs as array for simplicity, or normalize
  trackId       String?
  projectId     String?
  createdAt     DateTime @default(now())
}

model HackathonParticipant {
  id               String    @id @default(uuid())
  hackathonId      String
  hackathon        Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  userId           String
  teamId           String
  role             String    // "leader" | "member"
  joinedAt         DateTime  @default(now())
  addedToPortfolio Boolean   @default(false)

  @@unique([hackathonId, userId])
}

model HackathonProject {
  id                       String    @id @default(uuid())
  hackathonId              String
  hackathon                Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  teamId                   String
  trackId                  String
  title                    String
  tagline                  String
  description              String
  problemSolved            String    @default("")
  techStack                String[]
  githubLink               String    @default("")
  demoLink                 String    @default("")
  videoLink                String    @default("")
  presentationLink         String    @default("")
  screenshots              String[]
  status                   String    // "draft" | "submitted" | "locked"
  submittedAt              DateTime?
  linkedPortfolioProjectId String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

// ── Global Models ─────────────────────────────────────────────────────────────

model Project {
  id               String   @id @default(uuid())
  title            String
  tagline          String   @default("")
  summary          String   @default("")
  description      String   @default("")
  problemStatement String   @default("")
  solution         String   @default("")
  impact           String   @default("")
  domain           String
  techStack        String[]
  tags             String[]
  category         String   @default("Portfolio Project")
  sdgMapping       String[]
  githubLink       String   @default("")
  liveDemo         String   @default("")
  demoVideo        String   @default("")
  pptLink          String   @default("")
  screenshots      String[]
  attachments      String[]
  authorId         String
  visibility       String   @default("public")
  status           String   @default("published")
  moderationStatus String   @default("approved")
  isFeatured       Boolean  @default(false)
  buildStatus      String   @default("completed")
  likes            String[]
  bookmarks        String[]
  views            Int      @default(0)
  version          Int      @default(1)
  teamId           String?
  teamMembers      Json     @default("[]")
  challengesFaced  String   @default("")
  learnings        String   @default("")
  futureScope      String   @default("")
  comments         Json     @default("[]")
  versionHistory   Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Idea {
  id               String   @id @default(uuid())
  title            String
  description      String
  problem          String   @default("")
  solution         String   @default("")
  domain           String
  tags             String[]
  sdgMapping       String[]
  targetAudience   String   @default("")
  estimatedEffort  String   @default("")
  authorId         String
  status           String   @default("open")
  seekingTeam      Boolean  @default(false)
  rolesNeeded      String[]
  likes            String[]
  bookmarks        String[]
  views            Int      @default(0)
  convertedToProjectId String?
  comments         Json     @default("[]")
  version          Int      @default(1)
  versionHistory   Json     @default("[]")
  summary          String   @default("")
  impact           String   @default("")
  feasibility      String   @default("")
  novelty          String   @default("")
  category         String   @default("")
  neededResources  String[]
  stage            String   @default("raw")
  risks            String   @default("")
  roadmap          String   @default("")
  visibility       String   @default("public")
  moderationStatus String   @default("pending")
  isFeatured       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Team {
  id          String   @id @default(uuid())
  name        String
  avatar      String   @default("")
  description String   @default("")
  leaderId    String
  memberIds   String[]
  skills      String[]
  isOpen      Boolean  @default(true)
  rolesNeeded String[]
  projectId   String?
  projectIds  String[]
  ideaIds     String[]
  activity    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  senderId  String
  receiverId String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Report {
  id           String   @id @default(uuid())
  reporterId   String
  reportedId   String
  targetType   String   // "user" | "project" | "idea"
  targetId     String
  reason       String
  description  String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  resolvedAt   DateTime?
  resolution   String?
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  details    String
  timestamp  DateTime @default(now())
}

